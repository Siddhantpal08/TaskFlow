# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=taskflow

# Authentication
JWT_SECRET=your_super_secret_jwt_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_min_32_chars

# Email (for OTP password reset) — via Mailtrap SDK
MAILTRAP_API_KEY=your_api_token
MAIL_FROM=hello@demomailtrap.com

# CORS — comma-separated allowed origins
CLIENT_URLS=http://localhost:5173,http://localhost:3000

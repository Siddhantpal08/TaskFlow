{
  "expo": {
    "name": "TaskFlow",
    "slug": "taskflow-mobile",
    "version": "1.0.0",
    "scheme": ["taskflow", "com.siddhantpal.taskflow"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060B12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#060B12"
      },
      "package": "com.siddhantpal.taskflow"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "cf7d58a2-194b-427f-8c51-29f08bbc594f"
      }
    }
  }
}
